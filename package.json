{
  "name": "turbo-lang",
  "displayName": "Turbo Language",
  "description": "Language support for Turbo (.tb) — syntax highlighting, snippets, LSP diagnostics, and completions",
  "version": "0.5.0",
  "publisher": "zvndev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZVN-DEV/turbo-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/ZVN-DEV/turbo-vscode/issues"
  },
  "homepage": "https://turbolang.dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "turbo",
    "turbo-lang",
    "tb",
    "systems programming",
    "compiled language"
  ],
  "icon": "icons/turbo-icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:turbo"
  ],
  "contributes": {
    "languages": [
      {
        "id": "turbo",
        "aliases": [
          "Turbo",
          "turbo"
        ],
        "extensions": [
          ".tb"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "toml",
        "filenames": [
          "turbo.toml"
        ]
      }
    ],
    "grammars": [
      {
        "language": "turbo",
        "scopeName": "source.turbo",
        "path": "./syntaxes/turbo.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "turbo",
        "path": "./snippets/turbo.json"
      }
    ],
    "configuration": {
      "title": "Turbo",
      "properties": {
        "turbo.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the turbo-lsp binary. Leave empty to auto-detect."
        }
      }
    },
    "configurationDefaults": {
      "[turbo]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": false,
        "editor.semanticHighlighting.enabled": true
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}
